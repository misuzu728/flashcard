  {theme:"family",type:"Band7+",front:"weaken intergenerational bonds",back:"世代間の絆を弱める"},
  {theme:"family",type:"Band7+",front:"the cornerstone of society",back:"社会の礎"},
];

const themeNames = {
  environment:"🌍 環境",society:"👥 社会",economy:"💰 経済",
  transport:"🚗 交通・都市",education:"🎓 教育",technology:"💻 テクノロジー",
  consumer:"🛒 消費",culture:"🌐 文化",healthcare:"🏥 健康",
  crime:"🚔 犯罪",media:"📺 メディア",work:"💼 仕事",family:"👨‍👩‍👧 家族"
};

let currentCards = [];
let idx = 0;
let learned = JSON.parse(localStorage.getItem('ielts_learned') || '{}');
// デフォルトを「日本語→英語」に設定
let direction = localStorage.getItem('ielts_direction') || 'jp_to_en';

function getKey(c) { return c.theme + ':' + c.front; }

function filterCards() {
  const theme = document.getElementById('themeFilter').value;
  const mode = document.getElementById('modeFilter').value;
  let result = cards.filter(c => theme === 'all' || c.theme === theme);
  if (mode === 'learned') result = result.filter(c => learned[getKey(c)]);
  if (mode === 'unlearned') result = result.filter(c => !learned[getKey(c)]);
  return result;
}

function render() {
  currentCards = filterCards();
  // 方向ボタン更新
  document.getElementById('dirBtn').textContent = direction === 'jp_to_en' ? '🔄 日→英' : '🔄 英→日';
  document.querySelector('.subtitle').textContent = direction === 'jp_to_en' ? '日本語 → 英語 練習モード' : '英語 → 日本語 練習モード';
  document.querySelector('.card-front .card-hint').textContent = direction === 'jp_to_en' ? 'クリックで英語を表示' : 'クリックで日本語を表示';
 
  if (currentCards.length === 0) {
	document.getElementById('cardFront').textContent = '該当カードなし';
	document.getElementById('cardBack').textContent = '';
	document.getElementById('cardTheme').textContent = '';
	document.getElementById('cardThemeBack').textContent = '';
	document.getElementById('cardType').textContent = '';
	document.getElementById('counter').textContent = '0 / 0';
	updateStats();
	return;
  }
  if (idx >= currentCards.length) idx = 0;
  if (idx < 0) idx = currentCards.length - 1;
  const c = currentCards[idx];
  const isLearned = learned[getKey(c)] ? ' ✅' : '';
  document.getElementById('cardTheme').textContent = themeNames[c.theme] + isLearned;
  document.getElementById('cardThemeBack').textContent = themeNames[c.theme] + isLearned;
  document.getElementById('cardType').textContent = c.type;
  // 方向に応じて表裏切替
  if (direction === 'jp_to_en') {
	document.getElementById('cardFront').textContent = c.back;  // 日本語が表
	document.getElementById('cardBack').textContent = c.front;  // 英語が裏
  } else {
	document.getElementById('cardFront').textContent = c.front; // 英語が表
	document.getElementById('cardBack').textContent = c.back;   // 日本語が裏
  }
  document.getElementById('counter').textContent = (idx + 1) + ' / ' + currentCards.length;
  document.getElementById('card').classList.remove('flipped');
  updateStats();
}

function updateStats() {
  const total = currentCards.length;
  const learnedNum = currentCards.filter(c => learned[getKey(c)]).length;
  const percent = total > 0 ? Math.round((learnedNum / total) * 100) : 0;
  document.getElementById('totalCount').textContent = total;
  document.getElementById('learnedCount').textContent = learnedNum;
  document.getElementById('progressPercent').textContent = percent + '%';
  document.getElementById('progressFill').style.width = percent + '%';
}

function flip() { document.getElementById('card').classList.toggle('flipped'); }
function next() { idx++; render(); }
function prev() { idx--; render(); }

function toggleDirection() {
  direction = direction === 'jp_to_en' ? 'en_to_jp' : 'jp_to_en';
  localStorage.setItem('ielts_direction', direction);
  render();
}

function shuffle() {
  for (let i = currentCards.length - 1; i > 0; i--) {
	const j = Math.floor(Math.random() * (i + 1));
	[currentCards[i], currentCards[j]] = [currentCards[j], currentCards[i]];
  }
  idx = 0;
  render();
}

function markLearned() {
  if (currentCards.length === 0) return;
  learned[getKey(currentCards[idx])] = true;
  localStorage.setItem('ielts_learned', JSON.stringify(learned));
  next();
}

function markUnlearned() {
  if (currentCards.length === 0) return;
  delete learned[getKey(currentCards[idx])];
  localStorage.setItem('ielts_learned', JSON.stringify(learned));
  next();
}

function resetProgress() {
  if (confirm('進捗を全てリセットしますか？')) {
	learned = {};
	localStorage.removeItem('ielts_learned');
	render();
  }
}

document.getElementById('themeFilter').addEventListener('change', () => { idx = 0; render(); });
document.getElementById('modeFilter').addEventListener('change', () => { idx = 0; render(); });

document.addEventListener('keydown', e => {
  if (e.code === 'Space') { e.preventDefault(); flip(); }
  if (e.code === 'ArrowRight') next();
  if (e.code === 'ArrowLeft') prev();
  if (e.code === 'Digit1') markLearned();
  if (e.code === 'Digit2') markUnlearned();
});

render();
</script>
</body>
</html>

